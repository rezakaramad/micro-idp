; Default TTL (how long DNS responses are cached by clients)
$TTL 60

; SOA = Start Of Authority (defines this DNS zone)
@   IN SOA ns.mgmt.rezakara.demo. admin.rezakara.demo. (
        1       ; serial number (increment if zone is manually changed)
        7200    ; refresh
        3600    ; retry
        1209600 ; expire
        60      ; negative cache TTL
)

; NS record = declares the authoritative nameserver for this zone
@   IN NS ns.mgmt.rezakara.demo.

; A record for the nameserver (must exist so it can be resolved)
; Host machine IP as seen from minikube-management cluster
ns  IN A  10.200.0.1

; mgmt.rezakara.demo
;  ├── SOA → I'm authoritative
;  ├── NS  → my DNS server is ns.mgmt.rezakara.demo
;  └── ns  → that server lives at 10.200.0.1

; --- external-dns will dynamically add records below ---